<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>DeskLink</string>
    <key>CFBundleDisplayName</key>
    <string>DeskLink</string>
    <key>CFBundleIdentifier</key>
    <string>com.desklink.mac</string>
    <key>CFBundleExecutable</key>
    <string>DeskLink</string>
    <!-- App icon: build_app.sh compiles AppIcon.iconset into AppIcon.icns and copies
         it into Contents/Resources. Shown in Finder for the .app (this is an
         LSUIElement app, so it has no Dock icon). -->
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <!-- Menu-bar-only app: no Dock icon. -->
    <key>LSUIElement</key>
    <true/>
    <key>NSHumanReadableCopyright</key>
    <string>DeskLink</string>
    <!-- Shown if macOS prompts for Local Network access when Wi-Fi (LAN) connections
         are enabled and a tablet on the same network connects. USB (adb reverse over
         loopback) does not require this. -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>DeskLink uses your local network to connect to your tablet over Wi-Fi when you enable Wi-Fi (LAN) connections.</string>
    <!-- Bonjour service advertised on the control port so the tablet can discover this
         Mac over Wi-Fi (required to advertise/browse via NWListener on macOS 15+). -->
    <key>NSBonjourServices</key>
    <array>
        <string>_desklink._tcp</string>
    </array>
</dict>
</plist>
